# =====================================================================
# Template voor .env.local — kopieer naar .env.local en vul in.
# Deploy deze keys NOOIT in versioning. .env.local staat in .gitignore.
# =====================================================================

# ---- Supabase ------------------------------------------------------
# Publieke waarden, mogen in de browser terechtkomen:
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<jouw supabase anon key>

# Service role — alleen server-side gebruiken, NOOIT exposen:
SUPABASE_SERVICE_ROLE_KEY=<jouw supabase service role key>

# ---- Google Gemini -------------------------------------------------
# Alleen server-side. Vraag een key aan op https://aistudio.google.com/app/apikey
GEMINI_API_KEY=<jouw gemini api key>

# ---- Publieke site-URL (voor metadata, sitemap, robots) ------------
# Laat dit in productie wijzen naar je echte domein, bv:
# NEXT_PUBLIC_SITE_URL=https://afgeleidenoefenen.nl
NEXT_PUBLIC_SITE_URL=http://localhost:3000
